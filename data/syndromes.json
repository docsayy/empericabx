      "pseudomonas": "Cefepime"
    },

    "pearls": [
      "Always cover atypicals in CAP."
    ]
  },

  {
    "id": "hap",
    "name": "Hospital Acquired Pneumonia",
    "description": "Pneumonia developing after hospital admission.",

    "organisms": {
      "typical": [
        "Pseudomonas",
        "Klebsiella",
        "MRSA"
      ]
    },

    "empiric": [
      "Vancomycin + Cefepime"
    ],

    "pearls": [
      "Assess for pseudomonas risk."
    ]
  },

  {
    "id": "uti",
    "name": "Urinary Tract Infection",
    "description": "Cystitis and pyelonephritis.",

    "organisms": {
      "typical": [
        "E coli",
        "Klebsiella"
      ]
    },

    "empiric": [
